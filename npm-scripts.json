{
  "name": "credicheck-app",
  "version": "1.0.0",
  "description": "CrediCheck - Sistema de consulta de referencias crediticias",
  "main": "app/page.tsx",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "next dev",
    "dev:backend": "cd backend && npm run dev",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "next build",
    "build:backend": "cd backend && npm run build",
    "start": "concurrently \"npm run start:frontend\" \"npm run start:backend\"",
    "start:frontend": "next start",
    "start:backend": "cd backend && npm start",
    "lint": "npm run lint:frontend && npm run lint:backend",
    "lint:frontend": "next lint",
    "lint:backend": "cd backend && npm run lint",
    "lint:fix": "npm run lint:frontend:fix && npm run lint:backend:fix",
    "lint:frontend:fix": "next lint --fix",
    "lint:backend:fix": "cd backend && npm run lint:fix",
    "format": "npm run format:frontend && npm run format:backend",
    "format:frontend": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "format:backend": "cd backend && npm run format",
    "test": "npm run test:backend",
    "test:backend": "cd backend && npm test",
    "test:watch": "cd backend && npm run test:watch",
    "test:coverage": "cd backend && npm run test:coverage",
    "db:generate": "cd backend && npm run db:generate",
    "db:migrate": "cd backend && npm run db:migrate",
    "db:migrate:deploy": "cd backend && npm run db:migrate:deploy",
    "db:migrate:reset": "cd backend && npm run db:migrate:reset",
    "db:seed": "cd backend && npm run db:seed",
    "db:studio": "cd backend && npm run db:studio",
    "db:push": "cd backend && npm run db:push",
    "db:pull": "cd backend && npm run db:pull",
    "setup": "npm install && cd backend && npm install",
    "setup:dev": "npm run setup && npm run db:migrate && npm run db:seed",
    "setup:prod": "npm run setup && npm run build && npm run db:migrate:deploy",
    "clean": "rm -rf .next node_modules backend/dist backend/node_modules",
    "clean:install": "npm run clean && npm run setup",
    "type-check": "tsc --noEmit",
    "type-check:backend": "cd backend && npm run type-check"
  },
  "keywords": [
    "credicheck",
    "credit",
    "references",
    "nextjs",
    "react",
    "typescript",
    "tailwindcss",
    "prisma",
    "express",
    "nodejs"
  ],
  "author": "CrediCheck Team",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2",
    "prettier": "^3.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}